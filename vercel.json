{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/.next",
  "framework": "nextjs",
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/portfolio/:path*", "destination": "/api/index" },
    { "source": "/instruments/:path*", "destination": "/api/index" },
    { "source": "/admin/:path*", "destination": "/api/index" },
    { "source": "/health", "destination": "/api/index" },
    { "source": "/docs", "destination": "/api/index" },
    { "source": "/openapi.json", "destination": "/api/index" }
  ],
  "crons": [
    { "path": "/admin/cron/retrain-fast", "schedule": "0 2 * * *" },
    { "path": "/admin/cron/retrain-main", "schedule": "0 2 1 * *" }
  ]
}
